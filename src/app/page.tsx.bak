'use client'
import { useEffect, useState } from 'react'
import { supabase } from '@/lib/supabase'
import Link from 'next/link'

export default function Home() {
  const [bets, setBets] = useState<any[]>([])

  useEffect(() => {
    supabase.from('bets').select('*').order('created_at', { ascending: false })
      .then(({ data }) => setBets(data || []))
  }, [])

  return (
    <main className="max-w-lg mx-auto p-6">
      <div className="flex justify-between items-center mb-8">
        <h1 className="text-3xl font-bold">🔥 ChallengeUp</h1>
        <Link href="/create"
          className="bg-black text-white px-4 py-2 rounded-lg font-semibold">
          + 내기 만들기
        </Link>
      </div>
      <div className="space-y-3">
        {bets.length === 0 && (
          <p className="text-center text-gray-400 py-12">아직 내기가 없어요!<br/>첫 번째 내기를 만들어보세요 🎯</p>
        )}
        {bets.map(bet => (
          <Link key={bet.id}border rounded-xl p-4 hover:border-black transition-colors cursor-pointer">
              <h2 className="font-semibold text-lg">{bet.title}</h2>
              <p className="text-gray-500 text-sm mt-1">{bet.description}</p>
              <p className="text-red-500 text-sm mt-2">
                ⏰ 마감: {new Date(bet.deadline).toLocaleDateString('ko-KR')}
              </p>
            </div>
          </Link>
        ))}
      </div>
    </main>
  )
}
